{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/refresh-meta-token",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/meta-sync",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/meta-sync?window=today",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/agent-briefs",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/refresh-aggregates",
      "schedule": "3,18,33,48 * * * *"
    }
  ]
}
